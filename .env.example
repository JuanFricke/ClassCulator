# --- App ---
APP_ENV=dev
APP_PORT=8000
SECRET_KEY=change-me

# --- Login da empresa (conta administradora semeada na migração) ---
EMPRESA_NOME=Administração
EMPRESA_EMAIL=empresa@classculator.local
EMPRESA_SENHA=trocar-esta-senha

# --- Postgres (used by docker-compose) ---
POSTGRES_USER=classculator
POSTGRES_PASSWORD=classculator
POSTGRES_DB=classculator
POSTGRES_PORT=5432

# --- Database URLs ---
# Async (used by FastAPI / SQLAlchemy AsyncEngine)
DATABASE_URL=postgresql+asyncpg://classculator:classculator@db:5432/classculator
# Sync (used by Alembic migrations)
SYNC_DATABASE_URL=postgresql+psycopg://classculator:classculator@db:5432/classculator

# --- Solver ---
SOLVER_DEFAULT=cpsat
SOLVER_TIMEOUT_S=30
HILL_CLIMBING_ITERATIONS=800
