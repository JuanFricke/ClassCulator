# Production environment for Hostinger VPS Docker Project.
# Copy values into Hostinger project environment (never commit real secrets).

APP_ENV=prod
ACME_EMAIL=admin@sampletester.xyz

# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-strong-key

EMPRESA_NOME=Administração
EMPRESA_EMAIL=empresa@sampletester.xyz
EMPRESA_SENHA=change-me-strong-password

POSTGRES_USER=classculator
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=classculator

DATABASE_URL=postgresql+asyncpg://classculator:CHANGE_DB_PASSWORD@db:5432/classculator
SYNC_DATABASE_URL=postgresql+psycopg://classculator:CHANGE_DB_PASSWORD@db:5432/classculator

SOLVER_DEFAULT=cpsat
SOLVER_TIMEOUT_S=30
HILL_CLIMBING_ITERATIONS=800
